{
  "name": "enterprise-guardrail-researcher",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "db:migrate": "node --import tsx server/db/migrate.ts",
    "traces:inspect": "node --import tsx server/db/inspectResearchRunTraces.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server/index.js",
    "test:server": "node --import tsx --test server/**/*.test.ts",
    "test:evals": "node --import tsx --test evals/validateCases.test.ts evals/releaseCoreDataset.test.ts evals/runDeterministicReleaseEvals.test.ts evals/runCacheSourceEvals.test.ts evals/runPublicSurfaceEvals.test.ts evals/compareBranchVsMain.test.ts evals/runProductResolutionGrader.test.ts evals/runGuardrailQualityGrader.test.ts",
    "evals:validate-cases": "node --import tsx evals/validateCases.ts",
    "evals:run-deterministic-release": "node --import tsx evals/runDeterministicReleaseEvals.ts",
    "evals:run-cache-source": "node --import tsx evals/runCacheSourceEvals.ts",
    "evals:run-public-surface": "node --import tsx evals/runPublicSurfaceEvals.ts",
    "evals:compare-branch-vs-main": "node --import tsx evals/compareBranchVsMain.ts",
    "evals:grade-product-resolution": "node --import tsx evals/runProductResolutionGrader.ts",
    "evals:grade-guardrail-quality": "node --import tsx evals/runGuardrailQualityGrader.ts"
  },
  "dependencies": {
    "@openai/agents": "^0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "openai": "^5.12.2",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
